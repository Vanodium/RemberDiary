# MySQL connection (defaults match docker-compose.mysql.yml)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rember
MYSQL_PASSWORD=rember
MYSQL_DATABASE=rember

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=30d

# Optional: transcription & summarization
# WHISPER_BIN=whisper
# WHISPER_MODEL=small
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b

# Weekly summary email (mocked to console; copy this file to .env to use)
# WEEKLY_EMAIL_HOUR=23
# WEEKLY_EMAIL_MINUTE=59
# WEEKLY_EMAIL_DEBUG=1
# WEEKLY_EMAIL_IGNORE_DAY=1
# WEEKLY_EMAIL_USE_SERVER_TIME=1
