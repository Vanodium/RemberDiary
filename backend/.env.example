# MySQL (defaults match docker-compose.mysql.yml for local dev)
# On Render + Aiven: copy host/port/user/password/database from the Aiven service
# overview; paste the CA certificate PEM into MYSQL_CA_CERT (required for Aiven SSL).
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rember
MYSQL_PASSWORD=rember
MYSQL_DATABASE=rember
# MYSQL_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=30d

# Email (required for login OTP and weekly summaries)
# Render free tier blocks SMTP ports — use Brevo over HTTPS in production:
# BREVO_API_KEY=xkeysib-...   (Brevo → SMTP & API → API keys — not the SMTP password)
# EMAIL_FROM=Rember <your-verified-sender@domain.com>
BREVO_API_KEY=
# RESEND_API_KEY=re_...
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_SECURE=0
EMAIL_FROM=Rember <noreply@rember.app>
# EMAIL_IGNORE=test@example.com,mock@data.rember

# Groq (free tier) — transcription + summaries on Render/Vercel/Aiven free plans.
# Sign up at https://console.groq.com/keys (no credit card).
# GROQ_API_KEY=gsk_...
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Local dev fallback: install whisper + ffmpeg, or set GROQ_API_KEY above.
# WHISPER_BIN=whisper
# WHISPER_MODEL=small
# WHISPER_LANGUAGE=en

# Local dev fallback: Ollama summaries when GROQ_API_KEY is unset.
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b

# Paid fallback (optional): OpenAI Whisper when GROQ_API_KEY is unset.
# OPENAI_API_KEY=sk-...
# OPENAI_WHISPER_MODEL=whisper-1

# Optional: weekly summary email schedule (server timezone)
# WEEKLY_EMAIL_HOUR=23
# WEEKLY_EMAIL_MINUTE=59
# WEEKLY_EMAIL_DEBUG=1
# WEEKLY_EMAIL_IGNORE_DAY=1
# WEEKLY_EMAIL_USE_SERVER_TIME=1
