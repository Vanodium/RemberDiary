{
  "name": "rember",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev --prefix frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "predev:backend": "lsof -ti :3001 | xargs kill -9 2>/dev/null || true",
    "dev:backend": "npm run dev --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
